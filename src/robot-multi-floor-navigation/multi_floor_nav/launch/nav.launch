<?xml version="1.0"?>
<launch>

    <!--- Run Jackal Gazebo -->  
    <arg name="paused" default="false"/>
    <arg name="use_sim_time" default="true"/>
    <arg name="gui" default="true"/>
    <arg name="headless" default="false"/>
    <arg name="debug" default="false"/>
    <arg name="world_name" default="$(find jackal_elevator)/worlds/modified_elevator.world" />
    <arg name="map_file0" default="$(find multi_floor_nav)/maps/map_level0.yaml"/>
    <arg name="map_file1" default="$(find multi_floor_nav)/maps/map_level1.yaml"/>
    
    <arg name="config" default="navigation" />
    <arg name="front_laser" default="true" />
    <arg name="scan_topic" default="front/scan" />

    <!-- Launch Gazebo with the specified world -->
    <include file="$(find jackal_elevator)/launch/jackal_repos_world.launch">
        <arg name="gui" value="$(arg gui)" />
        <arg name="use_sim_time" value="$(arg use_sim_time)" />
        <arg name="headless" value="$(arg headless)" />
        <arg name="world_name" value="$(arg world_name)" />
        <arg name="front_laser" value="$(arg front_laser)" />
    </include>

    <!-- Run the map server -->
    <!-- Load level 0 map -->
    <node name="map_server0" pkg="map_server" type="map_server" args="$(arg map_file0)">
        <remap from="map" to="map_level_0"/>
    </node>
    <!-- Load level 1 map -->
    <node name="map_server1" pkg="map_server" type="map_server" args="$(arg map_file1)">
        <remap from="map" to="map_level_1"/>
    </node>

    <!--- Run AMCL -->
    <node pkg="amcl" type="amcl" name="amcl">
        <remap from="scan" to="$(arg scan_topic)"/>
        <rosparam file="$(find multi_floor_nav)/configs/amcl.yaml" command="load"/>
    </node>

    <!--- Run Move Base -->
    <include file="$(find jackal_navigation)/launch/include/move_base.launch" />

    <!-- 使用改进 A* 全局规划器 -->
    <param name="move_base/base_global_planner" value="improved_global_planner/ImprovedAStarPlanner" />
    <rosparam ns="move_base/ImprovedAStarPlanner" subst_value="true">
      use_dijkstra: false          # false 时使用 A*（或改进 A*）
      use_improved_astar: false    # true: 使用 ImprovedAStarExpansion；false: 使用原始 AStarExpansion
      use_quadratic: true
      use_grid_path: false
      allow_unknown: true

      # ---------------- 密度自适应 A* 粗略参数（后续可调） ----------------
      # 密度计算：rho = (N_occ + lambda * N_inflation) / N_total
      adaptive_density_radius: 2        # 局部窗口半径 r，窗口大小 = (2r+1)^2
      adaptive_inflation_lambda: 0.5    # 膨胀区计数权重 lambda
      adaptive_threshold_open: 0.20     # rho below open threshold -> 宽阔模式
      adaptive_threshold_narrow: 0.45   # rho above narrow threshold -> 狭窄模式

      # 障碍惩罚权重（安全）
      adaptive_w_obs_open: 0.15
      adaptive_w_obs_normal: 0.45
      adaptive_w_obs_narrow: 0.90

      # 方向对齐权重（效率）
      adaptive_w_dir_open: 0.35
      adaptive_w_dir_normal: 0.25
      adaptive_w_dir_narrow: 0.15

      # Weighted A* 启发系数 alpha（速度）
      adaptive_alpha_open: 1.35
      adaptive_alpha_normal: 1.15
      adaptive_alpha_narrow: 1.00
    </rosparam>

    <!--- Run Jackal RViz -->  
    <include file="$(find jackal_viz)/launch/view_robot.launch">
        <arg name="config" value="$(arg config)"/>    
    </include>

    <!-- Run Change Map Node -->
    <node pkg="multi_floor_nav" type="change_map_node" name="change_map_node"/>

    <!-- Run Multi Floor Navigation Node -->
    <node pkg="multi_floor_nav" type="multi_floor_navigation_node" name="multi_floor_navigation_node" output="screen"/>

</launch>