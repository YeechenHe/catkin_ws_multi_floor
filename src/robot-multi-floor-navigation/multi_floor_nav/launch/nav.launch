<?xml version="1.0"?>
<launch>

    <!--- Run Jackal Gazebo -->  
    <arg name="paused" default="false"/>
    <arg name="use_sim_time" default="true"/>
    <arg name="gui" default="true"/>
    <arg name="headless" default="false"/>
    <arg name="debug" default="false"/>
    <arg name="world_name" default="$(find jackal_elevator)/worlds/modified_elevator.world" />
    <arg name="map_file0" default="$(find multi_floor_nav)/maps/map_level0.yaml"/>
    <arg name="map_file1" default="$(find multi_floor_nav)/maps/map_level1.yaml"/>
    
    <arg name="config" default="navigation" />
    <arg name="front_laser" default="true" />
    <arg name="scan_topic" default="front/scan" />
    <!-- 为 true 时启用 SPA-AMCL 模块 A：电梯出口区域初始化 -->
    <arg name="use_region_init" default="false" />
    <!-- 为 true 时启用 AP-AMCL 模块 B：切层窗口内临时提高 max_particles / recovery_alpha_fast（仅 L1 重定位阶段） -->
    <arg name="use_ap_amcl" default="false" />
    <!-- 为 true 时启用模块 C：重定位完成判据优化（C_t > tau 连续 K 帧才通过） -->
    <arg name="use_covariance_reloc" default="false" />
    <!-- 可选：覆盖 reloc_confidence_K（0 表示不覆盖，使用 YAML 中的默认值） -->
    <arg name="reloc_confidence_K_override" default="0" />
    <!-- 初值扰动（补充实验用）：对发布的 initialpose 加偏移，模拟出口估计不准；默认 0 表示不扰动 -->
    <arg name="init_pose_offset_x" default="0.0" />
    <arg name="init_pose_offset_y" default="0.0" />
    <arg name="init_pose_offset_theta" default="0.0" />
    <!-- 初始位姿协方差：让 AMCL 粒子有初始展开，nomotion update 才能使粒子分布有意义地演化 -->
    <arg name="init_sigma_xy" default="0.0" />
    <arg name="init_sigma_yaw" default="0.0" />
    <!-- 为 true 时使用 move_base 标准全局规划器 navfn（默认，减少 NO PATH）；false 使用 ImprovedAStarPlanner -->
    <arg name="use_navfn" default="true" />

    <!-- Launch Gazebo with the specified world -->
    <include file="$(find jackal_elevator)/launch/jackal_repos_world.launch">
        <arg name="gui" value="$(arg gui)" />
        <arg name="use_sim_time" value="$(arg use_sim_time)" />
        <arg name="headless" value="$(arg headless)" />
        <arg name="world_name" value="$(arg world_name)" />
        <arg name="front_laser" value="$(arg front_laser)" />
    </include>

    <!-- Run the map server -->
    <!-- Load level 0 map -->
    <node name="map_server0" pkg="map_server" type="map_server" args="$(arg map_file0)">
        <remap from="map" to="map_level_0"/>
    </node>
    <!-- Load level 1 map -->
    <node name="map_server1" pkg="map_server" type="map_server" args="$(arg map_file1)">
        <remap from="map" to="map_level_1"/>
    </node>

    <!--- Run AMCL -->
    <node pkg="amcl" type="amcl" name="amcl">
        <remap from="scan" to="$(arg scan_topic)"/>
        <rosparam file="$(find multi_floor_nav)/configs/amcl.yaml" command="load"/>
    </node>

    <!-- 全局规划器（须在 move_base 启动前设置）：use_navfn 为 true 时用 navfn；false 时用 ImprovedAStarPlanner -->
    <group if="$(arg use_navfn)">
        <param name="move_base/base_global_planner" value="navfn/NavfnROS" />
        <param name="move_base/NavfnROS/allow_unknown" value="true" />
    </group>
    <group unless="$(arg use_navfn)">
        <param name="move_base/base_global_planner" value="improved_global_planner/ImprovedAStarPlanner" />
        <rosparam ns="move_base/ImprovedAStarPlanner" subst_value="true">
          use_dijkstra: false
          use_improved_astar: false
          use_quadratic: true
          use_grid_path: false
          allow_unknown: true
          adaptive_density_radius: 2
          adaptive_inflation_lambda: 0.5
          adaptive_threshold_open: 0.20
          adaptive_threshold_narrow: 0.45
          adaptive_w_obs_open: 0.15
          adaptive_w_obs_normal: 0.45
          adaptive_w_obs_narrow: 0.90
          adaptive_w_dir_open: 0.35
          adaptive_w_dir_normal: 0.25
          adaptive_w_dir_narrow: 0.15
          adaptive_alpha_open: 1.35
          adaptive_alpha_normal: 1.15
          adaptive_alpha_narrow: 1.00
        </rosparam>
    </group>

    <!--- Run Move Base（路径规划统一走 move_base） -->
    <include file="$(find jackal_navigation)/launch/include/move_base.launch" />

    <!--- Run Jackal RViz -->  
    <include file="$(find jackal_viz)/launch/view_robot.launch">
        <arg name="config" value="$(arg config)"/>    
    </include>

    <!-- Run Change Map Node -->
    <node pkg="multi_floor_nav" type="change_map_node" name="change_map_node"/>

    <!-- SPA-AMCL 区域初始化参数（仅当 use_region_init:=true 时加载） -->
    <group if="$(arg use_region_init)">
        <rosparam file="$(find multi_floor_nav)/configs/spa_amcl_region_init.yaml" ns="multi_floor_navigation_node"/>
    </group>
    <!-- AP-AMCL 模块 B 切层窗口参数（仅当 use_ap_amcl:=true 时加载，用于 Baseline vs AP-AMCL 对比） -->
    <group if="$(arg use_ap_amcl)">
        <rosparam file="$(find multi_floor_nav)/configs/ap_amcl_floor_window.yaml" ns="multi_floor_navigation_node"/>
    </group>
    <!-- 模块 C 重定位置信度判据（仅当 use_covariance_reloc:=true 时加载） -->
    <group if="$(arg use_covariance_reloc)">
        <rosparam file="$(find multi_floor_nav)/configs/reloc_confidence_criterion.yaml" ns="multi_floor_navigation_node"/>
    </group>

    <!-- 初始位姿协方差：仅在不使用 module A 时从 launch arg 设置，避免覆盖 spa_amcl yaml -->
    <group unless="$(arg use_region_init)">
        <param name="multi_floor_navigation_node/region_init_sigma_x" value="$(arg init_sigma_xy)"/>
        <param name="multi_floor_navigation_node/region_init_sigma_y" value="$(arg init_sigma_xy)"/>
        <param name="multi_floor_navigation_node/region_init_sigma_yaw" value="$(arg init_sigma_yaw)"/>
    </group>

    <!-- 可选覆盖 K 值：reloc_confidence_K_override > 0 时覆盖 YAML 中的默认值 -->
    <group if="$(eval arg('reloc_confidence_K_override') > 0)">
        <param name="multi_floor_navigation_node/reloc_confidence_K"
               value="$(arg reloc_confidence_K_override)"/>
    </group>

    <!-- Run Multi Floor Navigation Node（初值扰动 / AP-AMCL / 模块 C 通过 args 或 rosparam 传入） -->
    <node pkg="multi_floor_nav" type="multi_floor_navigation_node" name="multi_floor_navigation_node" output="screen">
        <param name="init_pose_offset_x" value="$(arg init_pose_offset_x)"/>
        <param name="init_pose_offset_y" value="$(arg init_pose_offset_y)"/>
        <param name="init_pose_offset_theta" value="$(arg init_pose_offset_theta)"/>
    </node>

</launch>